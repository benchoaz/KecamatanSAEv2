# ==============================================
# WHATSAPP STACK - Environment Variables
# Copy file ini ke .env dan isi nilainya
# ==============================================

# --- DASHBOARD API TOKEN ---
# Ambil dari Dashboard Kecamatan → Settings → API Token → Buat Token Baru
# Paste nilai token di sini (hanya muncul sekali saat dibuat)
DASHBOARD_API_TOKEN=your_dashboard_api_token_here

# --- DASHBOARD URL (dari perspektif container Docker) ---
DASHBOARD_API_URL=http://dashboard-kecamatan-nginx
